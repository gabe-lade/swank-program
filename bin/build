#!/usr/bin/env bash
# One-shot production-parity build (what GitHub Pages will publish).
#   bin/build
set -euo pipefail
source "$(dirname "${BASH_SOURCE[0]}")/common.sh"
cd "$REPO_ROOT"

if [ -n "$SITE_NOTE" ]; then echo "note: $SITE_NOTE"; fi
JEKYLL_ENV=production exec bundle exec jekyll build -d "$SITE_DIR" "$@"
